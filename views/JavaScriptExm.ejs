<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="/CSS/meuEstilo.css" rel="stylesheet">
    <title>JavaScript Example</title>
</head>
<body>
    <div class="container">
        <header>
            <nav class="navegacao">
                <img class="Logotipo" src="/images/news_logo.png" alt="logo livraria uma">
                <a href="/">HTML-CSS</a>
                <a href="/BootstrapExm">Bootstrap Grid System</a>
                <a href="/JavaScriptExm">JavaScript</a>
                <a href="/#livros">Livros</a>
            </nav>
        </header>

        <!-- Título principal do exercício -->
        <h1>Exercício JS</h1>

        <!-- Div que contém os botões que ativam as funções JavaScript -->
        <div>
            <!-- Cada botão usa o atributo onclick para executar uma função ao ser clicado -->
            <button onclick="stringTemplate()">stringTemplate</button>
            <button onclick="comparacoes()">comparações</button>
            <button onclick="horas()">horas</button>
            <button onclick="arrayManip()">arrayManip</button>
            <button onclick="somaArrays()">somaArrays</button>
            <button onclick="pilotoFormulaUm()">formulaUm</button>
        </div>
        <div id="output"></div>
    </div>
    <div>
        <footer>Universidade da Madeira <span id="anoLetivo"></span></footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="/JS/JavaScriptExe.js"></script>
</body>
</html>