<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="/CSS/meuEstilo.css" rel="stylesheet">
    <title>Livraria UMa</title>
</head>
<body>
    <!--
      Exercício DOM: formulário interativo (HTML + CSS Bootstrap + public/js/form.js).
      O script no final do body garante que os getElementById encontram os nós já criados.
    -->
    <div class="container">
        <header>
            <nav class="navegacao">
                <img class="Logotipo" src="/images/news_logo.png" alt="logo livraria uma">
                <a href="/">HTML-CSS</a>
                <a href="/BootstrapExm">Bootstrap Grid System</a>
                <a href="/JavaScriptExm">JavaScript</a>
                <a href="#livros">Livros</a>
                <a href="/form">Formulário</a>
            </nav>
        </header>
        <h1>Adicionar comentários usando DOM</h1>
        <div>
            <form id="commentForm">
                <h2>Queres deixar um comentário?</h2>
                <div class="mb-3">
                    <label for="nameInput" class="form-label">Nome</label>
                    <input type="text" class="form-control" id="nameInput" placeholder="Nome">
                </div>
                <div class="mb-3">
                    <label for="emailInput" class="form-label">E-mail</label>
                    <input type="email" class="form-control" id="emailInput" placeholder="E-mail">
                </div>
                <div class="mb-3">
                    <!-- O atributo for deve coincidir com o id do controlo associado (acessibilidade e clique na etiqueta). -->
                    <label for="commentTextarea" class="form-label">Mensagem</label>
                    <textarea name="messages" class="form-control" id="commentTextarea" rows="4"
                            placeholder="Mensagem"></textarea>
                </div>
                <!-- type="submit" aciona o evento submit do <form>; a validação trata-se em JavaScript com preventDefault(). -->
                <button type="submit" class="btn btn-primary" id="submitButton">Submeter Comentário</button>
            </form>
        </div>
        <h2 class="mt-4">Comentários</h2>
        <div id="commentsSection" class="mt-3">
        </div>
    </div>
    <div>
        <footer>Universidade da Madeira <span id="anoLetivo"></span></footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="/JS/form.js"></script>
</body>
</html>